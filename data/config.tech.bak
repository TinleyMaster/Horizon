{
    "version":  "1.0",
    "ai":  {
               "provider":  "deepseek",
               "model":  "deepseek-chat",
               "api_key_env":  "DEEPSEEK_API_KEY",
               "temperature":  0.3,
               "max_tokens":  4096,
               "throttle_sec":  0,
               "analysis_concurrency":  1,
               "enrichment_concurrency":  1,
               "languages":  [
                                 "en",
                                 "zh"
                             ]
           },
    "email":  {
                  "enabled":  false,
                  "smtp_server":  "smtp.qq.com",
                  "smtp_port":  465,
                  "imap_server":  "imap.qq.com",
                  "imap_port":  993,
                  "email_address":  "",
                  "sender_name":  "Horizon Daily",
                  "subscribe_keyword":  "SUBSCRIBE",
                  "unsubscribe_keyword":  "UNSUBSCRIBE"
              },
    "sources":  {
                    "github":  [
                                   {
                                       "type":  "user_events",
                                       "username":  "karpathy",
                                       "enabled":  true
                                   },
                                   {
                                       "type":  "repo_releases",
                                       "owner":  "astral-sh",
                                       "repo":  "uv",
                                       "enabled":  true
                                   },
                                   {
                                       "type":  "repo_releases",
                                       "owner":  "microsoft",
                                       "repo":  "vscode",
                                       "enabled":  true
                                   },
                                   {
                                       "type":  "repo_releases",
                                       "owner":  "openai",
                                       "repo":  "openai-python",
                                       "enabled":  true
                                   }
                               ],
                    "hackernews":  {
                                       "enabled":  true,
                                       "fetch_top_stories":  30,
                                       "min_score":  50
                                   },
                    "rss":  [
                                {
                                    "name":  "Simon Willison",
                                    "url":  "https://simonwillison.net/atom/everything/",
                                    "enabled":  true,
                                    "category":  "ai-tools"
                                },
                                {
                                    "name":  "Hacker News Digest",
                                    "url":  "https://hnrss.org/frontpage?count=30",
                                    "enabled":  true,
                                    "category":  "technology"
                                },
                                {
                                    "name":  "InfoQ 中文",
                                    "url":  "https://www.infoq.cn/feed",
                                    "enabled":  true,
                                    "category":  "tech-news"
                                },
                                {
                                    "name":  "阮一峰的网络日志",
                                    "url":  "https://feeds.feedburner.com/ruanyifeng",
                                    "enabled":  true,
                                    "category":  "programming"
                                },
                                {
                                    "name":  "planet python",
                                    "url":  "https://planetpython.org/rss20.xml",
                                    "enabled":  true,
                                    "category":  "programming"
                                },
                                {
                                    "name":  "ArsTechnica",
                                    "url":  "https://feeds.arstechnica.com/arstechnica/index",
                                    "enabled":  true,
                                    "category":  "technology"
                                }
                            ],
                    "reddit":  {
                                   "enabled":  true,
                                   "subreddits":  [
                                                      {
                                                          "subreddit":  "MachineLearning",
                                                          "enabled":  true,
                                                          "sort":  "hot",
                                                          "time_filter":  "day",
                                                          "fetch_limit":  15,
                                                          "min_score":  50
                                                      },
                                                      {
                                                          "subreddit":  "LocalLLaMA",
                                                          "enabled":  true,
                                                          "sort":  "hot",
                                                          "fetch_limit":  15,
                                                          "min_score":  30
                                                      },
                                                      {
                                                          "subreddit":  "programming",
                                                          "enabled":  true,
                                                          "sort":  "hot",
                                                          "fetch_limit":  15,
                                                          "min_score":  50
                                                      }
                                                  ],
                                   "users":  [

                                             ],
                                   "fetch_comments":  5
                               },
                    "twitter":  {
                                    "enabled":  false,
                                    "users":  [

                                              ],
                                    "fetch_limit":  10,
                                    "fetch_reply_text":  false,
                                    "max_replies_per_tweet":  3,
                                    "max_tweets_to_expand":  10,
                                    "reply_min_likes":  5
                                },
                    "openbb":  {
                                   "enabled":  false,
                                   "fetch_filings":  false,
                                   "filings_provider":  "sec",
                                   "watchlists":  [
                                                      {
                                                          "name":  "megacaps",
                                                          "enabled":  true,
                                                          "provider":  "yfinance",
                                                          "fetch_limit":  20,
                                                          "category":  "equities",
                                                          "symbols":  [
                                                                          "AAPL",
                                                                          "MSFT",
                                                                          "NVDA",
                                                                          "GOOGL",
                                                                          "AMZN",
                                                                          "META",
                                                                          "TSLA"
                                                                      ]
                                                      }
                                                  ]
                               },
                    "ossinsight":  {
                                       "enabled":  true,
                                       "period":  "past_24_hours",
                                       "languages":  [
                                                         "All",
                                                         "Python",
                                                         "TypeScript",
                                                         "Rust",
                                                         "Go"
                                                     ],
                                       "keywords":  [

                                                    ],
                                       "min_stars":  10,
                                       "max_items":  30
                                   }
                },
    "filtering":  {
                      "ai_score_threshold":  6.0,
                      "time_window_hours":  24,
                      "max_items":  20,
                      "category_groups":  {
                                              "ai":  {
                                                         "name":  "AI / Machine Learning",
                                                         "limit":  5,
                                                         "categories":  [
                                                                            "ai-tools",
                                                                            "ai-news",
                                                                            "machine-learning",
                                                                            "llm"
                                                                        ]
                                                     },
                                              "tech":  {
                                                           "name":  "Technology",
                                                           "limit":  5,
                                                           "categories":  [
                                                                              "technology",
                                                                              "tech-news",
                                                                              "programming"
                                                                          ]
                                                       }
                                          },
                      "default_group":  "other",
                      "default_group_limit":  3
                  },
    "webhook":  {
                    "enabled":  true,
                    "url_env":  "HORIZON_WEBHOOK_URL",
                    "delivery":  "summary",
                    "overview_position":  "first",
                    "platform":  "feishu",
                    "layout":  "collapsible",
                    "fallback_layout":  "markdown",
                    "languages":  null,
                    "request_body":  {
                                         "msg_type":  "interactive",
                                         "card":  {
                                                      "schema":  "2.0",
                                                      "config":  {
                                                                     "wide_screen_mode":  true
                                                                 },
                                                      "header":  {
                                                                     "title":  {
                                                                                   "tag":  "plain_text",
                                                                                   "content":  "#{message_title}"
                                                                               },
                                                                     "template":  "blue"
                                                                 },
                                                      "body":  {
                                                                   "elements":  [
                                                                                    {
                                                                                        "tag":  "markdown",
                                                                                        "content":  "Horizon生成结果: #{result}\nHorizon日报重要资讯数量: #{important_items}/#{all_items}"
                                                                                    },
                                                                                    {
                                                                                        "tag":  "hr"
                                                                                    },
                                                                                    {
                                                                                        "tag":  "markdown",
                                                                                        "content":  "#{summary}"
                                                                                    }
                                                                                ]
                                                               }
                                                  }
                                     },
                    "headers":  ""
                }
}