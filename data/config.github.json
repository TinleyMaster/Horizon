  "webhook": {
    "enabled": true,
    "url_env": "HORIZON_WEBHOOK_URL",
    "delivery": "summary",
    "platform": "feishu",
    "overview_position": "first",
    "layout": "markdown",
    "fallback_layout": "markdown",
    "request_body": {
      "msg_type": "interactive",
      "card": {
        "schema": "2.0",
        "config": {
          "wide_screen_mode": true
        },
        "header": {
          "title": {
            "tag": "plain_text",
            "content": "☀️ Horizon AI 资讯日报"
          },
          "template": "blue"
        },
        "body": {
          "elements": [
            {
              "tag": "markdown",
              "content": "今日 #{important_items}/#{all_items} 条重要资讯"
            },
            {
              "tag": "hr"
            },
            {
              "tag": "markdown",
              "content": "#{summary}"
            }
          ]
        }
      }
    },
    "headers": ""
  }
