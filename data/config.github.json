        "name": "📄 论文与前沿研究",
        "limit": 5,
        "categories": [
          "research"
        ]
      },
      "ai-tools": {
        "name": "🛠 工具与框架",
        "limit": 5,
        "categories": [
          "ai-tools"
        ]
      },
      "ai-news": {
        "name": "📰 行业动态",
        "limit": 5,
        "categories": [
