    "twitter": {
      "enabled": false,
      "users": [],
      "fetch_limit": 10
    },
    "openbb": {
      "enabled": false
    },
    "ossinsight": {
      "enabled": true,
      "period": "past_24_hours",
      "languages": [
        "All",
        "Python",
        "TypeScript",
        "Rust"
      ],
      "keywords": [
        "ai",
        "llm",
        "agent",
        "rag",
        "mcp"
      ],
      "min_stars": 50,
      "max_items": 20
    }
